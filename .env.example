# =============================================================
# Liquibase External DB Configuration
# -------------------------------------------------------------
# Salin file ini ke .env lalu isi dengan kredensial database:
#   cp .env.example .env
#
# File .env sudah masuk .gitignore — JANGAN commit .env ke Git!
# =============================================================

# Host/IP database external
EXT_DB_HOST=127.0.0.1

# Port database (default MySQL: 3306)
EXT_DB_PORT=3306

# Nama database
EXT_DB_NAME=liquibase_dev

# Kredensial
EXT_DB_USER=liquibase_user
EXT_DB_PASS=liquibase_pass
