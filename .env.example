# =============================================================
# Liquibase External DB Configuration
# -------------------------------------------------------------
# Salin file ini ke .env lalu isi dengan kredensial database:
#   cp .env.example .env
#
# File .env sudah masuk .gitignore — JANGAN commit .env ke Git!
#
# FORMAT PENAMAAN VARIABEL:
#   Koneksi spesifik per DB  →  DB_{NAMA_DB}_{FIELD}
#   Fallback/default global  →  EXT_DB_{FIELD}
#
# Script lb.sh membaca prioritas berikut (dari atas ke bawah):
#   1. Flag --host / --db di command line
#   2. Variabel spesifik    DB_{NAMA_DB}_HOST, DB_{NAMA_DB}_PORT, dst.
#   3. Variabel global      EXT_DB_HOST, EXT_DB_PORT, dst.
#   4. Nilai default script  127.0.0.1:3306
# =============================================================

# ── Koneksi Default / Fallback (dipakai jika tidak ada variabel spesifik) ──
EXT_DB_HOST=127.0.0.1
EXT_DB_PORT=3306
EXT_DB_USER=root
EXT_DB_PASS=password

# ──────────────────────────────────────────────────────────────────────────
# Koneksi spesifik per database
# Format: DB_{NAMA_DB}_{FIELD}
# NAMA_DB harus SAMA PERSIS dengan nama folder di liquibase/{NAMA_DB}/
# ──────────────────────────────────────────────────────────────────────────

# Database: MBTL_INT_COBA
DB_MBTL_INT_COBA_HOST=172.24.169.100
DB_MBTL_INT_COBA_PORT=3306
DB_MBTL_INT_COBA_NAME=MBTL_INT_COBA
DB_MBTL_INT_COBA_USER=root
DB_MBTL_INT_COBA_PASS=password

# Database: MBTL_PAYMENT (contoh database kedua)
# DB_MBTL_PAYMENT_HOST=172.24.169.101
# DB_MBTL_PAYMENT_PORT=3306
# DB_MBTL_PAYMENT_NAME=MBTL_PAYMENT
# DB_MBTL_PAYMENT_USER=root
# DB_MBTL_PAYMENT_PASS=password

# Database: MBTL_AUDIT (contoh database ketiga)
# DB_MBTL_AUDIT_HOST=172.24.169.102
# DB_MBTL_AUDIT_PORT=3306
# DB_MBTL_AUDIT_NAME=MBTL_AUDIT
# DB_MBTL_AUDIT_USER=root
# DB_MBTL_AUDIT_PASS=password
