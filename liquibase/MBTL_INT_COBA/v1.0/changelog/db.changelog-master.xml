    <!--
        Master Changelog — MBTL_INT_COBA v1.0
        ───────────────────────────────────────
        Setiap <changeSet> menghubungkan file SQL dari 2 folder:
          - changelog/changes/  → SQL untuk CREATE/ALTER (forward migration)
          - rollback/           → SQL untuk DROP/REVERT (rollback)

        Cara menjalankan:
          ./scripts/lb.sh --external --db-name=MBTL_INT_COBA --ver=v1.0 update
          ./scripts/lb.sh --external --db-name=MBTL_INT_COBA --ver=v1.0 rollback-count --count=1
    -->

    <!-- ═══════════════════════════════════════════════════════
         Template changeset baru (copy-paste untuk setiap file baru)
         ═══════════════════════════════════════════════════════
    <changeSet id="000X-nama-changeset" author="nama_kamu" labels="v1.0">
        <sqlFile path="changelog/changes/000X-nama-changeset.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 endDelimiter=";"/>
        <rollback>
            <sqlFile path="rollback/000X-nama-changeset-rollback.sql"
                     relativeToChangelogFile="true"
                     splitStatements="true"
                     endDelimiter=";"/>
        </rollback>
    </changeSet>
    -->

